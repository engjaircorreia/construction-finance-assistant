# Django
DJANGO_SETTINGS_MODULE=config.settings.development
DJANGO_SECRET_KEY=change-me-only-in-local-development
DJANGO_DEBUG=True
DJANGO_ALLOWED_HOSTS=localhost,127.0.0.1
DJANGO_CSRF_TRUSTED_ORIGINS=http://localhost:8000
DJANGO_ADMIN_URL=controle-interno/
DJANGO_TIME_ZONE=America/Fortaleza
DJANGO_DATA_UPLOAD_MAX_MEMORY_SIZE=10485760
DJANGO_FILE_UPLOAD_MAX_MEMORY_SIZE=10485760
AXES_ENABLED=True
AXES_FAILURE_LIMIT=5
AXES_COOLOFF_TIME=1

# Database
POSTGRES_DB=construction_finance
POSTGRES_USER=construction_finance
POSTGRES_PASSWORD=change-me
POSTGRES_HOST=db
POSTGRES_PORT=5432
DATABASE_URL=postgresql://construction_finance:change-me@db:5432/construction_finance

# Redis / Celery
REDIS_URL=redis://redis:6379/0
CELERY_BROKER_URL=redis://redis:6379/0
CELERY_RESULT_BACKEND=redis://redis:6379/1

# Telegram
TELEGRAM_BOT_TOKEN=
TELEGRAM_ALLOWED_USER_IDS=

# OpenAI
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4.1-mini
OPENAI_REQUEST_TIMEOUT_SECONDS=8
OPENAI_DRAFT_REARRANGE_ENABLED=true
OPENAI_OFX_CLASSIFICATION_ENABLED=false

# Application defaults
DEFAULT_FROM_EMAIL=
DEFAULT_BANK_ACCOUNT=Main Account
DEFAULT_PAYER=Company

# Production notes:
# - Do not commit a real .env.
# - Create the real .env directly on the VPS.
# - In production, set DJANGO_SETTINGS_MODULE=config.settings.production.
# - In production, change DJANGO_ADMIN_URL to a private non-default path.
